<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F1F7FC">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/header_layout"
        android:layout_width="match_parent"
        android:layout_height="184dp"
        android:background="@drawable/bg_header_gradient"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:layout_marginStart="16dp"
            android:background="@drawable/bg_back_button"
            android:src="@drawable/ic_back"
            android:padding="6dp"
            app:tint="#FFFFFF"
            app:layout_constraintBottom_toBottomOf="@+id/tv_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/tv_title" />

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="70dp"
            android:layout_marginEnd="16dp"
            android:text="Quản lý lịch học"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/btn_back"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_subtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Học kỳ 1 - Năm học 2025-2026"
            android:textColor="#F1F7FC"
            android:textSize="18sp"
            app:layout_constraintEnd_toEndOf="@+id/tv_title"
            app:layout_constraintStart_toStartOf="@+id/tv_title"
            app:layout_constraintTop_toBottomOf="@+id/tv_title" />

    </androidx.constraintlayout.widget.ConstraintLayout>


    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@+id/header_layout"
        app:layout_constraintBottom_toBottomOf="parent">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="150dp"
        android:clipToPadding="false"
        >



    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/card_semester_info"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="24dp"
        android:background="@drawable/bg_card_white"
        android:padding="20dp"
        android:elevation="4dp"
        app:layout_constraintTop_toBottomOf="@+id/header_layout">

        <View
            android:id="@+id/view_left_accent"
            android:layout_width="4dp"
            android:layout_height="0dp"
            android:background="@drawable/bg_left_accent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <ImageView
            android:id="@+id/iv_calendar_icon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginStart="16dp"
            android:src="@drawable/ic_calendar"
            app:layout_constraintStart_toEndOf="@+id/view_left_accent"
            app:layout_constraintTop_toTopOf="@+id/tv_card_title"
            app:layout_constraintBottom_toBottomOf="@+id/tv_card_title" />

        <TextView
            android:id="@+id/tv_card_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="Thông tin học kỳ"
            android:textColor="#1E3A8A"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@+id/iv_calendar_icon"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/btn_edit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_btn_edit"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:text="Chỉnh sửa"
            android:textColor="#3B82F6"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/tv_card_title"
            app:layout_constraintBottom_toBottomOf="@+id/tv_card_title" />

        <TextView
            android:id="@+id/tv_lbl_start_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Ngày bắt đầu"
            android:textColor="#757575"
            android:textSize="14sp"
            app:layout_constraintStart_toStartOf="@+id/iv_calendar_icon"
            app:layout_constraintTop_toBottomOf="@+id/tv_card_title" />

        <TextView
            android:id="@+id/tv_val_start_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="02/09/2025"
            android:textColor="#1E3A8A"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@+id/tv_lbl_start_date"
            app:layout_constraintTop_toBottomOf="@+id/tv_lbl_start_date" />

        <TextView
            android:id="@+id/tv_lbl_end_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="40dp"
            android:text="Ngày kết thúc"
            android:textColor="#757575"
            android:textSize="14sp"
            app:layout_constraintStart_toEndOf="@+id/tv_val_start_date"
            app:layout_constraintTop_toTopOf="@+id/tv_lbl_start_date" />

        <TextView
            android:id="@+id/tv_val_end_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="15/01/2026"
            android:textColor="#1E3A8A"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@+id/tv_lbl_end_date"
            app:layout_constraintTop_toBottomOf="@+id/tv_lbl_end_date" />

        <TextView
            android:id="@+id/tv_lbl_total_weeks"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Tổng số tuần"
            android:textColor="#757575"
            android:textSize="14sp"
            app:layout_constraintStart_toStartOf="@+id/iv_calendar_icon"
            app:layout_constraintTop_toBottomOf="@+id/tv_val_start_date" />

        <TextView
            android:id="@+id/tv_val_total_weeks"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="19 tuần"
            android:textColor="#1E3A8A"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@+id/tv_lbl_total_weeks"
            app:layout_constraintTop_toBottomOf="@+id/tv_lbl_total_weeks" />

        <TextView
            android:id="@+id/tv_lbl_subjects"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Số môn học"
            android:textColor="#757575"
            android:textSize="14sp"
            app:layout_constraintStart_toStartOf="@+id/tv_lbl_end_date"
            app:layout_constraintTop_toTopOf="@+id/tv_lbl_total_weeks" />

        <TextView
            android:id="@+id/tv_val_subjects"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="8 môn"
            android:textColor="#1E3A8A"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@+id/tv_lbl_subjects"
            app:layout_constraintTop_toBottomOf="@+id/tv_lbl_subjects" />

        <View
            android:id="@+id/view_divider"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_marginTop="20dp"
            android:background="#E0E0E0"
            app:layout_constraintStart_toStartOf="@+id/iv_calendar_icon"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tv_val_total_weeks" />

        <TextView
            android:id="@+id/tv_lbl_progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Tiến độ học kỳ"
            android:textColor="#757575"
            android:textSize="12sp"
            app:layout_constraintStart_toStartOf="@+id/iv_calendar_icon"
            app:layout_constraintTop_toBottomOf="@+id/view_divider" />

        <TextView
            android:id="@+id/tv_val_progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="65% đã hoàn thành"
            android:textColor="#757575"
            android:textSize="12sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/tv_lbl_progress" />

        <ProgressBar
            android:id="@+id/progress_semester"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="0dp"
            android:layout_height="8dp"
            android:layout_marginTop="8dp"
            android:max="100"
            android:progress="65"
            android:progressDrawable="@drawable/custom_progress_bar"
            app:layout_constraintStart_toStartOf="@+id/iv_calendar_icon"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tv_lbl_progress" />

    </androidx.constraintlayout.widget.ConstraintLayout>


    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_today_schedule_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@+id/card_semester_info">

        <ImageView
            android:id="@+id/iv_book_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_book"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_today_schedule_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Lịch học hôm nay"
            android:textColor="#1E3A8A"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@+id/iv_book_icon"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:id="@+id/btn_add_new"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_btn_add"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="6dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_cong"
                app:tint="#1E3A8A" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="Thêm mới"
                android:textColor="#1E3A8A"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <HorizontalScrollView
        android:id="@+id/scroll_days_of_week"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:clipToPadding="false"
        android:paddingHorizontal="16dp"
        android:scrollbars="none"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/layout_today_schedule_header">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tab_monday"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="10dp"
                android:background="@drawable/bg_tab_selected"
                android:paddingHorizontal="16dp"
                android:paddingVertical="6dp"
                android:text="Thứ 2 (3)"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tab_tuesday"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="10dp"
                android:background="@drawable/bg_tab_unselected"
                android:paddingHorizontal="16dp"
                android:paddingVertical="6dp"
                android:text="Thứ 3 (2)"
                android:textColor="#94989B"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tab_wednesday"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="10dp"
                android:background="@drawable/bg_tab_unselected"
                android:paddingHorizontal="16dp"
                android:paddingVertical="6dp"
                android:text="Thứ 4 (1)"
                android:textColor="#94989B"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tab_thursday"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="10dp"
                android:background="@drawable/bg_tab_unselected"
                android:paddingHorizontal="16dp"
                android:paddingVertical="6dp"
                android:text="Thứ 5"
                android:textColor="#94989B"
                android:textSize="14sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="10dp"
                android:background="@drawable/bg_tab_unselected"
                android:paddingHorizontal="16dp"
                android:paddingVertical="6dp"
                android:text="Thứ 6"
                android:textColor="#94989B"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="10dp"
                android:background="@drawable/bg_tab_unselected"
                android:paddingHorizontal="16dp"
                android:paddingVertical="6dp"
                android:text="Thứ 7"
                android:textColor="#94989B"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="10dp"
                android:background="@drawable/bg_tab_unselected"
                android:paddingHorizontal="16dp"
                android:paddingVertical="6dp"
                android:text="Chủ nhật"
                android:textColor="#94989B"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>
    </HorizontalScrollView>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/card_course_python"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_card_white"
        android:padding="16dp"
        android:elevation="3dp"
        app:layout_constraintTop_toBottomOf="@+id/scroll_days_of_week">

        <View
            android:id="@+id/view_blue_accent"
            android:layout_width="4dp"
            android:layout_height="0dp"
            android:background="@drawable/bg_left_accent_blue"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_course_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="8dp"
            android:text="Lập trình Python nâng cao"
            android:textColor="#1E3A8A"
            android:textSize="18sp"
            android:textStyle="bold"

            app:layout_constraintStart_toEndOf="@+id/view_blue_accent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageButton
            android:id="@+id/btn_delete"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/bg_btn_action"
            android:padding="6dp"
            android:src="@drawable/ic_trash3"
            app:tint="#757575"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageButton
            android:id="@+id/btnedit"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_btn_action"
            android:padding="6dp"
            android:src="@drawable/ic_pen"
            app:tint="#FF7043"
            app:layout_constraintEnd_toStartOf="@+id/btn_delete"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/iv_time"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginTop="12dp"
            android:src="@drawable/ic_whiteclock"
            app:layout_constraintStart_toStartOf="@+id/tv_course_name"
            app:layout_constraintTop_toBottomOf="@+id/tv_course_name" />

        <TextView
            android:id="@+id/tv_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="07:00"
            android:textColor="#757575"
            android:textSize="16sp"
            app:layout_constraintBottom_toBottomOf="@+id/iv_time"
            app:layout_constraintStart_toEndOf="@+id/iv_time"
            app:layout_constraintTop_toTopOf="@+id/iv_time" />

        <ImageView
            android:id="@+id/iv_room"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginTop="12dp"
            android:src="@drawable/ic_school"
            app:layout_constraintStart_toStartOf="@+id/tv_course_name"
            app:layout_constraintTop_toBottomOf="@+id/iv_time" />

        <TextView
            android:id="@+id/tv_room"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Phòng A203"
            android:textColor="#757575"
            android:textSize="16sp"
            app:layout_constraintBottom_toBottomOf="@+id/iv_room"
            app:layout_constraintStart_toEndOf="@+id/iv_room"
            app:layout_constraintTop_toTopOf="@+id/iv_room" />


    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/card_course_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_card_white"
        android:padding="16dp"
        android:elevation="3dp"
        app:layout_constraintTop_toBottomOf="@+id/card_course_python"> <View
        android:id="@+id/view_blue_accent_2"
        android:layout_width="4dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_left_accent_blue"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_course_name_2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="8dp"
            android:text="Cấu trúc dữ liệu &amp; Giải thuật"
            android:textColor="#1E3A8A"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@+id/btn_edit_2"
            app:layout_constraintStart_toEndOf="@+id/view_blue_accent_2"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageButton
            android:id="@+id/btn_delete_2"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/bg_btn_action"
            android:padding="6dp"
            android:src="@drawable/ic_trash3"
            app:tint="#757575"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageButton
            android:id="@+id/btn_edit_2"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_btn_action"
            android:padding="6dp"
            android:src="@drawable/ic_pen"
            app:tint="#FF7043"
            app:layout_constraintEnd_toStartOf="@+id/btn_delete_2"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/iv_time_2"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginTop="12dp"
            android:src="@drawable/ic_whiteclock"
            app:layout_constraintStart_toStartOf="@+id/tv_course_name_2"
            app:layout_constraintTop_toBottomOf="@+id/tv_course_name_2" />

        <TextView
            android:id="@+id/tv_time_2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="13:00"
            android:textColor="#757575"
            android:textSize="16sp"
            app:layout_constraintBottom_toBottomOf="@+id/iv_time_2"
            app:layout_constraintStart_toEndOf="@+id/iv_time_2"
            app:layout_constraintTop_toTopOf="@+id/iv_time_2" />

        <ImageView
            android:id="@+id/iv_room_2"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginTop="12dp"
            android:src="@drawable/ic_school"
            app:layout_constraintStart_toStartOf="@+id/tv_course_name_2"
            app:layout_constraintTop_toBottomOf="@+id/iv_time_2" />

        <TextView
            android:id="@+id/tv_room_2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Phòng C202"
            android:textColor="#757575"
            android:textSize="16sp"
            app:layout_constraintBottom_toBottomOf="@+id/iv_room_2"
            app:layout_constraintStart_toEndOf="@+id/iv_room_2"
            app:layout_constraintTop_toTopOf="@+id/iv_room_2" />

    </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/card_course_3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_card_white"
            android:padding="16dp"
            android:elevation="3dp"
            app:layout_constraintTop_toBottomOf="@+id/card_course_2"> <View
            android:id="@+id/view_blue_accent_3"
            android:layout_width="4dp"
            android:layout_height="0dp"
            android:background="@drawable/bg_left_accent_blue"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tv_course_name_3"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="8dp"
